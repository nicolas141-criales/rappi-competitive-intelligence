# ══════════════════════════════════════════════════════════════════════════════
# Rappi Competitive Intelligence — .env
# Copia como ".env" y ajusta los valores que necesites
# ══════════════════════════════════════════════════════════════════════════════

# ── Modo de ejecución ─────────────────────────────────────────────────────────
# mock → datos demo realistas (sin Playwright, para desarrollo y presentación)
# live → scraping real controlado (requiere Playwright instalado)
SCRAPING_MODE=mock

# ── Browser ───────────────────────────────────────────────────────────────────
HEADLESS=false          # false = menos detectable, mejor para demos
BROWSER=chromium
SLOW_MO=150

# ── Rate limiting (valores conservadores para no ser bloqueado) ───────────────
MIN_DELAY=8
MAX_DELAY=15
MAX_RETRIES=3
MAX_ADDRESSES=50        # Cobertura completa CDMX (50 zonas × 3 plataformas)

# ── Proxy (opcional, solo si tienes proxies residenciales propios) ─────────────
PROXY_ENABLED=false
# PROXY_LIST=http://user:pass@proxy1:port,http://user:pass@proxy2:port

# ── API providers opcionales (elige uno, o ninguno para Playwright directo) ───
# ZenRows: https://www.zenrows.com → 1,000 req gratis sin tarjeta
# ZENROWS_API_KEY=tu_key_aqui

# ScraperAPI: https://scraperapi.com → 1,000 req gratis sin tarjeta
# SCRAPERAPI_KEY=tu_key_aqui
# Si no configuras ninguno → Playwright directo (recomendado para demo)

# ── Cache de resultados ───────────────────────────────────────────────────────
CACHE_TTL_HOURS=6           # Horas antes de re-scrapear (default: 6h)

# ── Plataformas a comparar ────────────────────────────────────────────────────
PLATFORMS=rappi,ubereats,didi

# ── Screenshots (evidencia visual del scraping) ───────────────────────────────
SCREENSHOTS_ENABLED=true

# ── OpenAI (opcional, para AI insights más ricos) ─────────────────────────────
# OPENAI_API_KEY=sk-...
